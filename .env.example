# ── Supabase ──────────────────────────────────────────────────────────────
# Public — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# SECRET — server-only. Used exclusively inside Edge Functions / server actions.
# Never import this in a Client Component or expose it via NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Site ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://styleatlas.ng

# ── Resend (transactional email) — SECRET, used in Edge Functions only ────
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL="STYLEATLAS <hello@styleatlas.ng>"

# ── Paystack — secret keys used in Edge Functions only ───────────────────
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx
PAYSTACK_WEBHOOK_SECRET=whsec_paystack_xxx

# ── Flutterwave — secret keys used in Edge Functions only ────────────────
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxx
FLUTTERWAVE_WEBHOOK_SECRET=your-flutterwave-webhook-hash

# ── OpenAI (AI live chat) — SECRET, used only inside Edge Functions ───────
OPENAI_API_KEY=sk-xxx

# ── Misc ──────────────────────────────────────────────────────────────────
# Used by Edge Functions to sign/verify internal service-to-service calls
INTERNAL_FUNCTION_SECRET=generate-a-long-random-string
